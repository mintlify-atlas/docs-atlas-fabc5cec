  "keyFeatures": [
    "AI-powered educational assistance using Google Gemini",
    "Interactive exercises for Spanish language and mathematics",
    "Real-time exercise correction with detailed explanations",
    "Teacher and student dashboards with progress tracking",
    "Model Context Protocol (MCP) integration for educational content",
    "Exercise generation with difficulty levels (basic, intermediate, advanced)",
    "Conversational AI interface for natural learning",
    "Dark mode support with responsive design"
  ],
  "publicApiSurface": [
    "POST /assistant/interact - Main assistant interaction endpoint",
    "POST /assistant/correct - Correct exercises with AI feedback",
    "POST /assistant/generate-exercise - Generate new exercises",
    "POST /assistant/explain - Get topic explanations",
    "POST /assistant/correct-answer - Correct specific answers",
    "GET /assistant/modules - Get available educational modules",
    "GET /assistant/exercises/:module - Get exercises by module",
    "GET /assistant/exercises-by-ids/:ids - Get exercises by IDs",
    "GET /assistant/theory/:exerciseId - Get theory for exercise",
    "GET /assistant/theory-simplified/:exerciseId - Get simplified explanations",
    "GET /assistant/Edu - Health check endpoint"
  ]
